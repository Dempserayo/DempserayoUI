{
  "name": "dempserayo-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/dempserayo-ui.umd.cjs",
  "module": "./dist/dempserayo-ui.js",
